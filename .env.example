# Copy this file to .env and fill in your keys

# Required: Anthropic API key (get one at console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Twitter API v2 Bearer Token (significant quality upgrade for scraping)
# Get one at developer.twitter.com — Basic tier ($100/mo) gives you tweet reads
TWITTER_BEARER_TOKEN=AAAA...
